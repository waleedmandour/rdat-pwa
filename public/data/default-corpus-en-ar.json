  {
    "id": "tm-001",
    "en": "Neither party shall be held liable for failure to perform obligations under this agreement due to events beyond reasonable control.",
    "ar": "لا يتحمل أي من الطرفين مسؤولية الإخلال بالتزاماته بموجب هذا الاتفاق في حالة حدوث قوة قاهرة.",
    "context": "Legal — force majeure clause",
    "type": "translation_memory"
  },
  {
    "id": "tm-002",
    "en": "American military aircraft conducted reconnaissance operations near the disputed border region.",
    "ar": "أجرت الطائرات العسكرية الأمريكية عمليات استطلاع بالقرب من منطقة الحدود المتنازع عليها.",
    "context": "Military — reconnaissance",
    "type": "translation_memory"
  },
  {
    "id": "tm-003",
    "en": "The United States imposed new sanctions on Iran over its nuclear program.",
    "ar": "فرضت الولايات المتحدة عقوبات جديدة على إيران بسبب برنامجها النووي.",
    "context": "International relations — sanctions",
    "type": "translation_memory"
  },
  {
    "id": "tm-004",
    "en": "The Security Council convened an emergency session to discuss the ceasefire agreement.",
    "ar": "عقد مجلس الأمن جلسة طارئة لمناقشة اتفاق وقف إطلاق النار.",
    "context": "UN — Security Council proceedings",
    "type": "translation_memory"
  },
  {
    "id": "tm-005",
    "en": "The two nations agreed to restore diplomatic relations after years of tensions.",
    "ar": "اتفقت الدولتان على استعادة العلاقات الدبلوماسية بعد سنوات من التوترات.",
    "context": "Diplomacy — bilateral relations",
    "type": "translation_memory"
  },
  {
    "id": "tm-006",
    "en": "This agreement shall be governed by and construed in accordance with the laws of the jurisdiction in which the originating party is domiciled.",
    "ar": "يخضع هذا الاتفاق ويُفسّر وفقًا لقوانين الاختصاص القضائي الذي يقع فيه مقر الطرف الأصلي.",
    "context": "Legal — governing law clause",
    "type": "translation_memory"
  },
  {
    "id": "tm-007",
    "en": "The United Nations Security Council condemned the human rights violations in the region.",
    "ar": "أدان مجلس الأمن التابع للأمم المتحدة انتهاكات حقوق الإنسان في المنطقة.",
    "context": "UN — Security Council resolutions",
    "type": "translation_memory"
  },
  {
    "id": "tm-008",
    "en": "All intellectual property rights including patents, trademarks and copyrights remain with the originating party.",
    "ar": "تظل جميع حقوق الملكية الفكرية بما في ذلك براءات الاختراع والعلامات التجارية وحقوق النشر للطرف الأصلي.",
    "context": "Legal — intellectual property",
    "type": "translation_memory"
  },
  {
    "id": "tm-009",
    "en": "The minister of foreign affairs called for an immediate ceasefire and the resumption of peace negotiations.",
    "ar": "دعا وزير الخارجية إلى وقف فوري لإطلاق النار واستئناف مفاوضات السلام.",
    "context": "Diplomacy — peace process",
    "type": "translation_memory"
  },
  {
    "id": "tm-010",
    "en": "The General Assembly adopted a resolution calling for the protection of civilian populations during armed conflicts.",
    "ar": "اعتمدت الجمعية العامة قرارًا يدعو إلى حماية السكان المدنيين أثناء النزاعات المسلحة.",
    "context": "UN — General Assembly resolution",
    "type": "translation_memory"
  },
  {
    "id": "tm-011",
    "en": "The coalition government faces growing opposition from both liberal and conservative factions in parliament.",
    "ar": "تواجه الحكومة الائتلافية معارضة متزايدة من كل من الفصائل الليبرالية والمحافظة في البرلمان.",
    "context": "Domestic politics — government formation",
    "type": "translation_memory"
  },
  {
    "id": "tm-012",
    "en": "The European Union imposed economic sanctions on the regime for its continued human rights abuses.",
    "ar": "فرض الاتحاد الأوروبي عقوبات اقتصادية على النظام بسبب استمراره في انتهاكات حقوق الإنسان.",
    "context": "International relations — EU sanctions",
    "type": "translation_memory"
  },
  {
    "id": "tm-013",
    "en": "The referendum on constitutional amendments saw a record voter turnout across all provinces.",
    "ar": "شهد الاستفتاء على التعديلات الدستورية نسبة مشاركة قياسية في جميع المقاطعات.",
    "context": "Elections — constitutional referendum",
    "type": "translation_memory"
  },
  {
    "id": "tm-014",
    "en": "The World Bank and the International Monetary Fund issued a joint statement on the economic reforms.",
    "ar": "أصدر البنك الدولي وصندوق النقد الدولي بيانًا مشتركًا بشأن الإصلاحات الاقتصادية.",
    "context": "International organizations — financial institutions",
    "type": "translation_memory"
  },
  {
    "id": "tm-015",
    "en": "The president signed the amended legislation into law, granting greater autonomy to the southern provinces.",
    "ar": "وقّع الرئيس التشريع المعدّل ليصبح قانونًا، مما يمنح حكمًا ذاتيًا أوسع للمقاطعات الجنوبية.",
    "context": "Domestic politics — legislation signing",
    "type": "translation_memory"
  },
  {
    "id": "tm-016",
    "en": "The Arab League Secretary-General called for an emergency summit to discuss the escalating tensions.",
    "ar": "دعا أمين عام جامعة الدول العربية إلى قمة طارئة لمناقشة التصعيد المتزايد في التوترات.",
    "context": "Regional organizations — Arab League",
    "type": "translation_memory"
  },
  {
    "id": "tm-017",
    "en": "Intelligence reports confirmed that military aircraft had violated the no-fly zone established by the Security Council.",
    "ar": "أكدت تقارير المخابرات أن الطائرات العسكرية قد انتهكت منطقة حظر الطيران التي أنشأها مجلس الأمن.",
    "context": "Security — no-fly zone violation",
    "type": "translation_memory"
  },
  {
    "id": "tm-018",
    "en": "The human rights organization documented widespread torture and arbitrary detention in the occupied territories.",
    "ar": "وثّقت منظمة حقوق الإنسان حالات واسعة من التعذيب والاحتجاز التعسفي في الأراضي المحتلة.",
    "context": "Human rights — documentation of violations",
    "type": "translation_memory"
  },
  {
    "id": "tm-019",
    "en": "The opposition leader called for free and transparent elections under international supervision.",
    "ar": "دعا زعيم المعارضة إلى انتخابات حرة وشفافة تحت إشراف دولي.",
    "context": "Elections — opposition demands",
    "type": "translation_memory"
  },
  {
    "id": "tm-020",
    "en": "The defense ministry announced the deployment of fighter jets along the disputed border region.",
    "ar": "أعلنت وزارة الدفاع نشر مقاتلات نفاثة على طول منطقة الحدود المتنازع عليها.",
    "context": "Military — border deployment",
    "type": "translation_memory"
  }
]
